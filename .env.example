# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp Cloud API v23
# Long-lived system user token — generate via Meta Business Suite > System Users
WHATSAPP_CLOUD_ACCESS_TOKEN=
# Numeric phone number ID — found in Meta App Dashboard > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=
# Self-chosen string configured in Meta App Dashboard > Webhooks
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# App Secret — found in Meta App Dashboard > Settings > Basic
WHATSAPP_APP_SECRET=

# Vercel Cron authentication
# Set this in Vercel dashboard; Vercel sends it automatically on cron invocations
CRON_SECRET=

# Railway Service (retired — Railway still runs for Retell/Sheets only)
# RAILWAY_SERVICE_URL=
# RAILWAY_API_SECRET=

# Luma (lu.ma)
LUMA_API_KEY=
LUMA_WEBHOOK_SECRET=

# Sentry (Next.js)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Sentry (Railway — set in Railway dashboard, not here)
# SENTRY_DSN=
# LOG_LEVEL=info
